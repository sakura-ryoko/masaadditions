  "masaadditions.config.configs_extended2.generic.comment.blockBreakingParticleLimit": "This controls the maximum number of block breaking\nparticles produced per block broken if the\n'Block Breaking Particle Tweaks' tweak is enabled.\nThe default in vanilla is 64 particles per block.\nPorted from 1.12 Tweakeroo.",
  "masaadditions.config.configs_extended2.generic.comment.blockBreakingParticleScale": "This is just an extra option for some fun looking\nblock breaking particles. Works if you have the\n'Block Breaking Particle Tweaks' tweak enabled.\nPorted from 1.12 Tweakeroo.",
  "masaadditions.config.configs_extended2.generic.comment.blockBreakingParticleSpeedMultiplier": "This is just an extra option for some fun looking\nblock breaking particles. Works if you have the\n'Block Breaking Particle Tweaks' tweak enabled.\nPorted from 1.12 Tweakeroo.",
  "masaadditions.config.configs_extended2.generic.comment.clickRecipeCraft": "Craft a recipe by clicking on it in the recipe book\nwhile holding CTRL and SHIFT modifier keys.\nHold ALT modifier key to throw crafted items.\nThis feature is originally from UsefulMod by nessie.",
  "masaadditions.config.configs_extended2.generic.comment.cloudHeight": "This controls the height of clouds in the Overworld dimension.",
  "masaadditions.config.configs_extended2.generic.comment.derpyChicken": "Makes chickens always face upwards.\nThis feature is originally from CutelessMod by nessie.",
  "masaadditions.config.configs_extended2.generic.comment.handRestockContinuous": "If enabled, then hand restocking is attempted every tick,\nwhereas normally it only happens before and after\nleft/right clicks or in the fast block placement mode.\nPorted from 1.12 Tweakeroo.\n§6It is recommended to have this disabled, §6unless you\nknow you will need it for some specific use case.",
  "masaadditions.config.configs_extended2.generic.comment.gridRestrictX": "If enabled, then grid restriction will work along the X axis.",
  "masaadditions.config.configs_extended2.generic.comment.gridRestrictY": "If enabled, then grid restriction will work along the Y axis.",
  "masaadditions.config.configs_extended2.generic.comment.gridRestrictZ": "If enabled, then grid restriction will work along the Z axis.",
  "masaadditions.config.configs_extended2.generic.comment.scoreboardSidebarMaxLength": "This controls the maximum length of the scoreboard sidebar.",
  "masaadditions.config.configs_extended2.generic.comment.skyTimeOverride": "The day time to use when overriding the time used for rendering the sky if the Override Sky Time tweak is enabled.",
  "masaadditions.config.configs_extended2.generic.comment.windowTitleOverride": "The title used to override the default instance window title if the Override Window Title tweak is enabled.",
  "masaadditions.config.configs_extended2.lists.comment.perimeterOutlineBlocksList": "The block types checked by the Perimeter Wall Dig Helper tweak.",
  "masaadditions.config.configs_extended2.lists.comment.preventAttackEntitiesList": "The entity types checked by the Prevent Attack Entities tweak.",
  "masaadditions.config.configs_extended2.lists.comment.swapAlmostBrokenToolsWhitelist": "A whitelist of tools checked by the Swap Almost Broken Tools tweak.",
  "masaadditions.config.configs_extended2.lists.comment.swapAlmostBrokenToolsBlacklist": "A blacklist of tools checked by the Swap Almost Broken Tools tweak.",
  "masaadditions.config.configs_extended2.disable.comment.disableBeaconBeamRendering": "Disables rendering of beacon beams.",
  "masaadditions.config.configs_extended2.disable.comment.disableBedExplosions": "Prevents player from using beds while in the Nether or End\nwhich would cause the bed to explode.",
  "masaadditions.config.configs_extended2.disable.comment.disableBlockAttackedParticles": "Removes block particles that are rendered on sides of blocks when attacked.",
  "masaadditions.config.configs_extended2.disable.comment.disableBossBarRendering": "Disables rendering of boss bars.",
  "masaadditions.config.configs_extended2.disable.comment.disableChristmasChests": "Disables the Christmas texture for chests.",
  "masaadditions.config.configs_extended2.disable.comment.disableDragonEggTeleporting": "Prevents player from attacking (outside of creative mode)\nor using dragon eggs while not shifting.",
  "masaadditions.config.configs_extended2.disable.comment.disableFarmlandMaking": "Disables making farmland with a hoe.\nFast right click is disabled while this is enabled.",
  "masaadditions.config.configs_extended2.disable.comment.disableFootstepParticles": "Removes players' footstep particles.",
  "masaadditions.config.configs_extended2.disable.comment.disableHoneyBlockSlowdown": "Removes the slowdown from walking on honey blocks.",
  "masaadditions.config.configs_extended2.disable.comment.disableHoneyBlockJumping": "Prevents player from jumping while on honey blocks.",
  "masaadditions.config.configs_extended2.disable.comment.disableItemFrameFrameRendering": "Disables rendering of item frame frames.\nThis feature is originally from UsefulMod by nessie.",
  "masaadditions.config.configs_extended2.disable.comment.disableOtherPlayerRendering": "Disables rendering of other players.",
  "masaadditions.config.configs_extended2.disable.comment.disablePathMaking": "Disables making path blocks with a shovel.",
  "masaadditions.config.configs_extended2.disable.comment.disablePlantBlockModelOffset": "Disables the random XZ offsetting of plant block models.\nThis feature is originally from UsefulMod by nessie.",
  "masaadditions.config.configs_extended2.disable.comment.disableRealmsButton": "Disables the 'Minecraft Realms' button on the title screen.\nThis feature is originally from UsefulMod by nessie.",
  "masaadditions.config.configs_extended2.disable.comment.disableScoreboardSidebarRendering": "Disables rendering of scoreboard sidebar.",
  "masaadditions.config.configs_extended2.disable.comment.disableSleepingNotification": "Prevents the sleeping status from being displayed in the action bar.",
  "masaadditions.config.configs_extended2.disable.comment.disableSlimeBlockBouncing": "Prevents player from bouncing on slime blocks.",
  "masaadditions.config.configs_extended2.disable.comment.disableSnowLayerStacking": "Prevents player from placing multiple snow layers in a block.",
  "masaadditions.config.configs_extended2.disable.comment.disableSprintingUnderwater": "Prevents player from sprinting underwater with the Disable Swimming tweak.\nAlso, prevents player from sprinting in one block tall water with the\nPermanent Sprint tweak, which is not possible in Vanilla, if enabled.",
  "masaadditions.config.configs_extended2.disable.comment.disableStuckArrowsRendering": "Disables rendering of stuck arrows.",
  "masaadditions.config.configs_extended2.disable.comment.disableSwimming": "Disables swimming while sprinting underwater.",
  "masaadditions.config.configs_extended2.internal.comment.honeyBlockVelocityMultiplierOriginal": "The original velocity value of Honey Blocks",
  "masaadditions.config.configs_extended2.internal.comment.honeyBlockJumpVelocityMultiplierOriginal": "The original jump velocity value of Honey Blocks",
  "masaadditions.config.feature_toggle_extended.comment.tweakAlwaysRenderBarrierParticles": "Barrier block particles will always be rendered regardless of\nthe player's current gamemode and held item if enabled.",
  "masaadditions.config.feature_toggle_extended.comment.tweakBlockBreakingParticleTweaks": "Allows tweaking the block breaking particles, such as reducing the number\nof particles produced per block broken.\nSet the limit in Generic -> 'Block Breaking Particle Limit'.\nPorted from 1.12 Tweakeroo.",
  "masaadditions.config.feature_toggle_extended.comment.tweakForceSwapGear": "Allows the player to equip an armor piece in their main hand by\nright clicking while sneaking even if the player already has\narmor in the respective armor slot. This also works with elytras.",
  "masaadditions.config.feature_toggle_extended.comment.tweakInsaneBlockBreakingParticles": "Changes block breaking particles to have no gravity and increased velocity.\nThis feature is originally from UsefulMod by nessie.",
  "masaadditions.config.feature_toggle_extended.comment.tweakItemNameCopy": "Sets item name in anvil to string stored in clipboard.",
  "masaadditions.config.feature_toggle_extended.comment.tweakLlamaSteering": "Allows the player to control Llamas while riding them.\nPorted from 1.12 Tweakeroo.",
  "masaadditions.config.feature_toggle_extended.comment.tweakMovementHold": "Emulates holding down the movement keys that were\ncurrently pressed when the tweak is enabled.",
  "masaadditions.config.feature_toggle_extended.comment.tweakNameTagPiglins": "Only allows player to use name tags on piglins holding swords",
  "masaadditions.config.feature_toggle_extended.comment.tweakOneHitKill": "Enables one hit killing attacked living entities if player is in creative.\nRequires operator permission to use /kill.",
  "masaadditions.config.feature_toggle_extended.comment.tweakOverrideSkyTime": "Overrides the day time used for rendering the sky.\nInspired by tweakDayCycleOverride in Tweakfork by Andrews54757.\nAllows you to see the actual time through mods such as MiniHUD\nor using the Clock item unlike tweakDayCycleOverride.",
  "masaadditions.config.feature_toggle_extended.comment.tweakOverrideWindowTitle": "Replaces the current window title with the string\nspecified in the Window Title Override generic config.",
  "masaadditions.config.feature_toggle_extended.comment.tweakPerimeterWallDigHelper": "Prevents player from mining underneath the block types\nspecified in the Perimeter Outline Blocks list.",
  "masaadditions.config.feature_toggle_extended.comment.tweakPreventAttackEntities": "Prevents player from attacking entities with the entity types\nspecified in the Prevent Attack Entities list.",
  "masaadditions.config.feature_toggle_extended.comment.tweakRainbowLeaves": "Makes leaves more colorful.\nThis feature is originally from UsefulMod by nessie.",
  "masaadditions.config.feature_toggle_extended.comment.tweakRespawnOnDeath": "Enables automatic respawning on death.\nThis feature is originally from UsefulMod by nessie.",
  "masaadditions.config.hotkeys_extended2.comment.blinkDrive": "Teleports the player (using a tp command) to the location the player is looking at.\nPorted from 1.12 Tweakeroo.",
  "masaadditions.config.hotkeys_extended2.comment.blinkDriveYLevel": "Teleports the player (using a tp command)\nto the location  the player is looking at,\nbut it maintains the current y-position.\nPorted from 1.12 Tweakeroo.",
  "masaadditions.config.hotkeys_extended2.comment.replacementMode": "While block placing, replaces the block you're looking at instead of placing against it.\nOnly works if you are opped or in singleplayer.",
